# ============================================
# 需求工作室后端配置
# 复制此文件为 .env 并填入实际值
# ============================================

# 服务端口
PORT=3456

# ---------- AI API 类型 ----------
# 可选：openai | anthropic
AI_API_TYPE=openai

# ========== 方案 A：OpenAI 兼容格式 ==========
# 适用：OpenAI / DeepSeek / 通义千问 / Moonshot / Ollama 等
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# 其他 OpenAI 兼容示例：
# AI_API_URL=https://api.deepseek.com/v1/chat/completions
# AI_MODEL=deepseek-chat
#
# AI_API_URL=http://localhost:11434/v1/chat/completions
# AI_MODEL=qwen2.5:7b

# ========== 方案 B：Anthropic Messages API ==========
# 适用：Anthropic 官方 / tokenhub 代理 等
# 使用此方案时，设置 AI_API_TYPE=anthropic 并填写下方配置：
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
